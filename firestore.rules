rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários só acessam seus próprios dados
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Categorias
      match /categorias/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Produtos
      match /produtos/{prodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Leitura pública para o cardápio do cliente (produtos ativos)
        allow read: if resource.data.ativo == true;
      }

      // Pedidos
      match /pedidos/{pedidoId} {
        // Admin pode ler/escrever tudo
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Clientes podem criar pedidos (sem autenticação)
        allow create: if true;
      }
    }

    // Leitura pública do estabelecimento para o cardápio
    match /users/{userId} {
      allow read: if true;
    }
  }
}
